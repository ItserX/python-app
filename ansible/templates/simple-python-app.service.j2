[Unit]
Description=Simple Python App Service
After=network.target

[Service]
Type=simple
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_dir }}
Environment=APP_HOST={{ app_host }}
Environment=APP_PORT={{ app_port }}
ExecStart=/usr/bin/python3 {{ app_dir }}/app/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
